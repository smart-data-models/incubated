{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$schemaVersion": "0.0.1",
  "modelTags": "OSM OpenStreetMap POI Shop",
  "$id": "https://smart-data-models.github.io/dataModel.OpenStreetMap/OSMShop/schema.json",
  "title": "Smart Data Models - OpenStreetMap / OSMShop",
  "description": "A shop or retail store from OpenStreetMap tagged with shop=*. Represents establishments selling retail products directly to end customers",
  "type": "object",
"derivedFrom": "https://wiki.openstreetmap.org/wiki/Key:shop",
  "allOf": [
    {
      "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/GSMA-Commons"
    },
    {
      "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/Location-Commons"
    },
    {
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "OSMShop"
          ],
          "description": "Property. NGSI Entity type. It has to be OSMShop"
        },
        "osmId": {
          "type": "integer",
          "description": "Property. The original OpenStreetMap element integer identifier"
        },
        "osmType": {
          "type": "string",
          "enum": [
            "node",
            "way",
            "relation"
          ],
          "description": "Property. The type of the original OSM element"
        },
        "osmLastModified": {
          "type": "string",
          "format": "date-time",
          "description": "Property. Timestamp of the last modification"
        },
        "shopType": {
          "type": "string",
          "enum": [
            "supermarket",
            "convenience",
            "bakery",
            "butcher",
            "greengrocer",
            "deli",
            "clothes",
            "shoes",
            "boutique",
            "tailor",
            "jewelry",
            "optician",
            "cosmetics",
            "hairdresser",
            "beauty",
            "massage",
            "tattoo",
            "car",
            "car_repair",
            "bicycle",
            "hardware",
            "electronics",
            "mobile_phone",
            "computer",
            "doityourself",
            "florist",
            "gift",
            "books",
            "stationery",
            "sports",
            "fishing",
            "outdoor",
            "pet",
            "toys",
            "furniture",
            "interior_decoration",
            "laundry",
            "dry_cleaning"
          ],
          "description": "Property. The OSM shop tag classifying the retail category. Enum:'supermarket, convenience, bakery, clothes, shoes, hairdresser, car_repair, bicycle, hardware, electronics, florist, books...'. Model:'https://wiki.openstreetmap.org/wiki/Key:shop'"
        },
        "brand": {
          "type": "string",
          "description": "Property. The brand name if the shop is part of a chain or franchise. Model:'https://wiki.openstreetmap.org/wiki/Key:brand'"
        },
        "operator": {
          "type": "string",
          "description": "Property. Name of the entity operating the shop. Model:'https://wiki.openstreetmap.org/wiki/Key:operator'"
        },
        "organic": {
          "type": "string",
          "enum": [
            "yes",
            "no",
            "only"
          ],
          "description": "Property. Indicates if the shop sells organic products. Model:'https://wiki.openstreetmap.org/wiki/Key:organic'"
        },
        "wheelchair": {
          "type": "string",
          "enum": [
            "yes",
            "no",
            "limited"
          ],
          "description": "Property. Wheelchair accessibility. Model:'https://wiki.openstreetmap.org/wiki/Key:wheelchair'"
        },
        "openingHours": {
          "type": "string",
          "description": "Property. Opening hours of the shop in OSM format. Model:'https://wiki.openstreetmap.org/wiki/Key:opening_hours'"
        },
        "phone": {
          "type": "string",
          "description": "Property. Phone number for the shop"
        },
        "website": {
          "type": "string",
          "format": "uri",
          "description": "Property. Official website URL"
        },
        "address": {
          "type": "object",
          "description": "Property. Address of the Shop, structured following schema.org PostalAddress",
          "properties": {
            "streetAddress": {
              "type": "string",
              "description": "Property. Street name"
            },
            "houseNumber": {
              "type": "string",
              "description": "Property. House or building number"
            },
            "addressCity": {
              "type": "string",
              "description": "Property. City of the address"
            },
            "postalCode": {
              "type": "string",
              "description": "Property. Postal code"
            },
            "addressCountry": {
              "type": "string",
              "description": "Property. ISO 3166-1 alpha-2 country code"
            }
          }
        },
        "seeAlso": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uri"
              },
              "minItems": 1
            },
            {
              "type": "string",
              "format": "uri"
            }
          ],
          "description": "Property. List of URIs pointing to additional resources"
        }
      }
    }
  ],
  "required": [
    "id",
    "type",
    "location",
    "osmId",
    "osmType",
    "shopType"
  ]
}