{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$schemaVersion": "0.0.1",
  "modelTags": "OSM OpenStreetMap POI Tourism",
  "$id": "https://smart-data-models.github.io/dataModel.OpenStreetMap/OSMTourism/schema.json",
  "title": "Smart Data Models - OpenStreetMap / OSMTourism",
  "description": "A tourist attraction or tourism-related facility from OpenStreetMap tagged with tourism=*. Includes hotels, museums, viewpoints, artworks, etc",
  "type": "object",
"derivedFrom": "https://wiki.openstreetmap.org/wiki/Key:tourism",
  "allOf": [
    {
      "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/GSMA-Commons"
    },
    {
      "$ref": "https://smart-data-models.github.io/data-models/common-schema.json#/definitions/Location-Commons"
    },
    {
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "OSMTourism"
          ],
          "description": "Property. NGSI Entity type. It has to be OSMTourism"
        },
        "osmId": {
          "type": "integer",
          "description": "Property. The original OpenStreetMap element integer identifier"
        },
        "osmType": {
          "type": "string",
          "enum": [
            "node",
            "way",
            "relation"
          ],
          "description": "Property. The type of the original OSM element"
        },
        "osmLastModified": {
          "type": "string",
          "format": "date-time",
          "description": "Property. Timestamp of the last modification"
        },
        "tourismType": {
          "type": "string",
          "enum": [
            "hotel",
            "motel",
            "hostel",
            "guest_house",
            "chalet",
            "apartment",
            "camp_site",
            "caravan_site",
            "alpine_hut",
            "wilderness_hut",
            "museum",
            "gallery",
            "theme_park",
            "zoo",
            "aquarium",
            "attraction",
            "viewpoint",
            "artwork",
            "information",
            "picnic_site"
          ],
          "description": "Property. The OSM tourism tag classification. Enum:'hotel, motel, hostel, guest_house, chalet, apartment, camp_site, caravan_site, alpine_hut, wilderness_hut, museum, gallery, theme_park, zoo, aquarium, attraction, viewpoint, artwork, information, picnic_site'. Model:'https://wiki.openstreetmap.org/wiki/Key:tourism'"
        },
        "stars": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "description": "Property. Hotel star rating. Model:'https://wiki.openstreetmap.org/wiki/Key:stars'"
        },
        "rooms": {
          "type": "integer",
          "minimum": 1,
          "description": "Property. Number of rooms in a hotel or guest house. Model:'https://wiki.openstreetmap.org/wiki/Key:rooms'"
        },
        "artworkType": {
          "type": "string",
          "enum": [
            "sculpture",
            "statue",
            "mural",
            "bust",
            "architecture",
            "graffiti",
            "installation",
            "painting"
          ],
          "description": "Property. Specific type of artwork if tourism=artwork. Model:'https://wiki.openstreetmap.org/wiki/Key:artwork_type'"
        },
        "information": {
          "type": "string",
          "enum": [
            "guidepost",
            "board",
            "map",
            "office",
            "terminal",
            "audioguide"
          ],
          "description": "Property. Type of information provided if tourism=information. Model:'https://wiki.openstreetmap.org/wiki/Key:information'"
        },
        "fee": {
          "type": "boolean",
          "description": "Property. Indicates whether an entrance fee is required"
        },
        "wheelchair": {
          "type": "string",
          "enum": [
            "yes",
            "no",
            "limited"
          ],
          "description": "Property. Wheelchair accessibility"
        },
        "address": {
          "type": "object",
          "description": "Property. Address of the amenity, structured following schema.org PostalAddress",
          "properties": {
            "streetAddress": {
              "type": "string",
              "description": "Property. Street name"
            },
            "houseNumber": {
              "type": "string",
              "description": "Property. House or building number"
            },
            "addressCity": {
              "type": "string",
              "description": "Property. City of the address"
            },
            "postalCode": {
              "type": "string",
              "description": "Property. Postal code"
            },
            "addressCountry": {
              "type": "string",
              "description": "Property. ISO 3166-1 alpha-2 country code"
            }
          }
        },
        "seeAlso": {
          "oneOf": [
            {
              "type": "array",
              "items": {
                "type": "string",
                "format": "uri"
              },
              "minItems": 1
            },
            {
              "type": "string",
              "format": "uri"
            }
          ],
          "description": "Property. List of URIs pointing to additional resources"
        }
      }
    }
  ],
  "required": [
    "id",
    "type",
    "location",
    "osmId",
    "osmType",
    "tourismType"
  ]
}